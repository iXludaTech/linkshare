{
    "name": "legato/linkshare",
    "description": "LinkShare — A community-driven platform to discover and share the best learning resources.",
    "keywords": ["linkshare", "php", "links", "sharing", "curated", "learning"],
    "license": "MIT",
    "type": "project",
    "authors": [
        {
            "name": "iXluda-Tech",
            "email": "iXluda@tech.com"
        }
    ],
    "require": {
        "php": ">=7.1.0",
        "legato/framework": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "copy__missing_env": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-root-package-install": [
            "@composer copy__missing_env"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}
