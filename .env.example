APP_URL=linkshare.test
APP_NAME='LinkShare'
APP_DEBUG=true
APP_ENV=local

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linkshare
DB_USERNAME=root
DB_PASSWORD=

# Template engine (twig is recommended)
TEMPLATE_ENGINE=twig

# reCAPTCHA (get keys at https://www.google.com/recaptcha/admin)
RECAPTCHA_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET=your_recaptcha_secret_key

# Mail
MAIL_DRIVER=mailgun
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_SECRET=your_mailgun_api_key

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
